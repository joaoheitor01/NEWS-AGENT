# ============================================================================
# Tech News Agent — variáveis de ambiente
# Copie para `.env` (ou configure no painel da Vercel). NUNCA versione segredos.
# ============================================================================

# Chave da API do OpenRouter (OPCIONAL).
# Sem ela, o app funciona com curadoria heurística (sem IA).
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Modelo do OpenRouter (opcional). Padrão: openrouter/auto
# Ex.: openai/gpt-4o-mini, google/gemini-flash-1.5, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=openrouter/auto

# Tópico do ntfy.sh para o push diário do cron (opcional).
# Padrão: aion_news_jh_2026
NTFY_TOPIC=

# URL do site (opcional) usada no header HTTP-Referer do OpenRouter.
SITE_URL=

# Base da API para builds nativos (Capacitor). No deploy web, deixe vazio.
# Ex.: https://seu-projeto.vercel.app
VITE_API_BASE=
